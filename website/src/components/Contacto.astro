---
import Icon from "./Icon.astro";

// Datos de contacto — reemplazar los marcadores por la información real.
const info = [
  {
    icon: "pin",
    label: "Dirección",
    value: "[DIRECCIÓN]",
    href: null,
  },
  {
    icon: "phone",
    label: "Teléfono",
    value: "[TELÉFONO]",
    href: "tel:[TELÉFONO]",
  },
  {
    icon: "whatsapp",
    label: "WhatsApp",
    value: "[WHATSAPP]",
    href: "https://wa.me/[WHATSAPP]",
  },
  {
    icon: "mail",
    label: "Correo Electrónico",
    value: "[CORREO]",
    href: "mailto:[CORREO]",
  },
];
---

<section class="section" id="contacto">
  <div class="container">
    <div class="section__head">
      <p class="section__eyebrow">Estamos para ayudarte</p>
      <h2 class="section__title">Contáctanos</h2>
      <p class="section__subtitle">
        Estamos disponibles para atender tus proyectos y brindarte asesoría
        profesional.
      </p>
      <div class="section__divider"></div>
    </div>

    <div class="contact">
      <!-- Información -->
      <div class="contact__info" data-reveal>
        <h3 class="contact__info-title">Información de contacto</h3>
        <p class="contact__info-text">
          Cuéntanos sobre tu proyecto y un asesor te responderá a la brevedad.
        </p>

        <ul class="contact__list">
          {
            info.map((c) => (
              <li class="cinfo">
                <span class="cinfo__icon" aria-hidden="true">
                  <Icon name={c.icon} size={22} />
                </span>
                <span class="cinfo__body">
                  <span class="cinfo__label">{c.label}</span>
                  {c.href ? (
                    <a class="cinfo__value" href={c.href}>
                      {c.value}
                    </a>
                  ) : (
                    <span class="cinfo__value">{c.value}</span>
                  )}
                </span>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Formulario -->
      <form class="contact__form" data-reveal data-reveal-delay="1" novalidate>
        <div class="field">
          <label for="nombre">Nombre</label>
          <input type="text" id="nombre" name="nombre" autocomplete="name" required />
        </div>

        <div class="field-row">
          <div class="field">
            <label for="telefono">Teléfono</label>
            <input type="tel" id="telefono" name="telefono" autocomplete="tel" required />
          </div>
          <div class="field">
            <label for="correo">Correo Electrónico</label>
            <input type="email" id="correo" name="correo" autocomplete="email" required />
          </div>
        </div>

        <div class="field">
          <label for="asunto">Asunto</label>
          <input type="text" id="asunto" name="asunto" required />
        </div>

        <div class="field">
          <label for="mensaje">Mensaje</label>
          <textarea id="mensaje" name="mensaje" rows="5" required></textarea>
        </div>

        <button type="submit" class="btn btn--primary contact__submit">
          Enviar Mensaje
          <Icon name="arrow" size={18} />
        </button>

        <p class="contact__status" id="form-status" role="status" aria-live="polite"></p>
      </form>
    </div>
  </div>
</section>

<style>
  .contact {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  .contact__info-title {
    font-size: 1.4rem;
    margin-bottom: 0.75rem;
  }
  .contact__info-text {
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }
  .contact__list {
    display: grid;
    gap: 1.25rem;
  }
  .cinfo {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }
  .cinfo__icon {
    flex-shrink: 0;
    display: inline-grid;
    place-items: center;
    width: 50px;
    height: 50px;
    border-radius: 14px;
    background: var(--color-navy);
    color: #fff;
  }
  .cinfo__body {
    display: flex;
    flex-direction: column;
    padding-top: 0.15rem;
  }
  .cinfo__label {
    font-family: var(--font-heading);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-steel);
    margin-bottom: 0.2rem;
  }
  .cinfo__value {
    font-size: 1.02rem;
    color: var(--color-text);
    transition: color 0.2s;
  }
  a.cinfo__value:hover {
    color: var(--color-navy);
  }

  /* Formulario */
  .contact__form {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: clamp(1.75rem, 4vw, 2.75rem);
    box-shadow: var(--shadow-md);
  }
  .field {
    margin-bottom: 1.25rem;
    display: flex;
    flex-direction: column;
  }
  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }
  .field label {
    font-family: var(--font-heading);
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-navy);
    margin-bottom: 0.5rem;
  }
  .field input,
  .field textarea {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text);
    padding: 0.85rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background: var(--color-accent);
    transition: border-color 0.25s, background 0.25s, box-shadow 0.25s;
    width: 100%;
    resize: vertical;
  }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--color-navy);
    background: #fff;
    box-shadow: 0 0 0 3px rgba(15, 45, 82, 0.1);
  }
  .field input:user-invalid,
  .field textarea:user-invalid {
    border-color: #c0392b;
  }
  .contact__submit {
    width: 100%;
    margin-top: 0.5rem;
  }
  .contact__status {
    margin-top: 1rem;
    text-align: center;
    font-size: 0.92rem;
    min-height: 1.2em;
  }
  .contact__status.is-ok {
    color: #1e7e34;
  }
  .contact__status.is-error {
    color: #c0392b;
  }

  @media (max-width: 820px) {
    .contact {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 480px) {
    .field-row {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>(".contact__form");
  const status = document.getElementById("form-status");

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    if (!status) return;
    status.className = "contact__status";

    if (!form.checkValidity()) {
      status.textContent = "Por favor completa todos los campos correctamente.";
      status.classList.add("is-error");
      form.reportValidity();
      return;
    }

    // Demostración front-end. Conectar a un endpoint/servicio de correo real.
    const data = new FormData(form);
    const nombre = String(data.get("nombre") ?? "");
    status.textContent = `Gracias${nombre ? ", " + nombre : ""}. Hemos recibido tu mensaje y te contactaremos pronto.`;
    status.classList.add("is-ok");
    form.reset();
  });
</script>
