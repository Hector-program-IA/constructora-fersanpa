---
import Icon from "./Icon.astro";

type Category = "residencial" | "comercial" | "publica";

interface Project {
  title: string;
  category: Category;
  label: string;
  img: string;
}

const projects: Project[] = [
  {
    title: "Residencia Lomas del Valle",
    category: "residencial",
    label: "Residencial",
    img: "1564013799919-ab600027ffc6",
  },
  {
    title: "Casa habitación contemporánea",
    category: "residencial",
    label: "Residencial",
    img: "1568605114967-8130f3a36994",
  },
  {
    title: "Edificio corporativo Centro",
    category: "comercial",
    label: "Comercial",
    img: "1486406146926-c627a92ad1ab",
  },
  {
    title: "Plaza comercial Angelópolis",
    category: "comercial",
    label: "Comercial",
    img: "1497366216548-37526070297c",
  },
  {
    title: "Vialidad y pavimentación urbana",
    category: "publica",
    label: "Obra Pública",
    img: "1581094794329-c8112a89af12",
  },
  {
    title: "Fraccionamiento residencial",
    category: "residencial",
    label: "Residencial",
    img: "1570129477492-45c003edd2be",
  },
  {
    title: "Local comercial premium",
    category: "comercial",
    label: "Comercial",
    img: "1554469384-e58fac16e23a",
  },
  {
    title: "Infraestructura y urbanización",
    category: "publica",
    label: "Obra Pública",
    img: "1473893604213-3df9c15cf5cd",
  },
  {
    title: "Casa residencial minimalista",
    category: "residencial",
    label: "Residencial",
    img: "1512917774080-9991f1c4c750",
  },
];

const filters = [
  { key: "all", label: "Todos" },
  { key: "residencial", label: "Residencial" },
  { key: "comercial", label: "Comercial" },
  { key: "publica", label: "Obra Pública" },
];

const src = (id: string, w = 800) =>
  `https://images.unsplash.com/photo-${id}?auto=format&fit=crop&w=${w}&q=80`;
---

<section class="section section--accent" id="galeria">
  <div class="container">
    <div class="section__head">
      <p class="section__eyebrow">Portafolio</p>
      <h2 class="section__title">Proyectos Realizados</h2>
      <p class="section__subtitle">
        Una muestra de los proyectos residenciales, comerciales y de obra
        pública desarrollados por nuestro equipo.
      </p>
      <div class="section__divider"></div>
    </div>

    <div class="filters" role="tablist" aria-label="Filtrar proyectos">
      {
        filters.map((f, i) => (
          <button
            class={`filter${i === 0 ? " is-active" : ""}`}
            data-filter={f.key}
            role="tab"
            aria-selected={i === 0 ? "true" : "false"}
          >
            {f.label}
          </button>
        ))
      }
    </div>

    <div class="gallery" id="gallery-grid">
      {
        projects.map((p, i) => (
          <button
            class="gitem"
            data-category={p.category}
            data-reveal
            data-reveal-delay={String((i % 4) + 1)}
            data-full={src(p.img, 1400)}
            data-title={p.title}
            data-label={p.label}
            aria-label={`Ampliar imagen: ${p.title}`}
          >
            <img src={src(p.img, 800)} alt={p.title} loading="lazy" width="800" height="600" />
            <span class="gitem__overlay">
              <span class="gitem__cat">{p.label}</span>
              <span class="gitem__title">{p.title}</span>
              <span class="gitem__zoom" aria-hidden="true">
                <Icon name="gallery" size={20} />
              </span>
            </span>
          </button>
        ))
      }
    </div>

    <p class="gallery__empty" id="gallery-empty" hidden>
      No hay proyectos en esta categoría por el momento.
    </p>
  </div>
</section>

<!-- Modal -->
<div class="modal" id="gallery-modal" hidden role="dialog" aria-modal="true" aria-label="Imagen ampliada">
  <div class="modal__backdrop" data-modal-close></div>
  <div class="modal__content">
    <button class="modal__close" data-modal-close aria-label="Cerrar">
      <Icon name="close" size={24} />
    </button>
    <img class="modal__img" id="modal-img" src="" alt="" />
    <div class="modal__caption">
      <span class="modal__cat" id="modal-cat"></span>
      <span class="modal__title" id="modal-title"></span>
    </div>
  </div>
</div>

<style>
  .filters {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }
  .filter {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.6rem 1.4rem;
    border-radius: 999px;
    background: #fff;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    transition: all 0.25s var(--ease);
  }
  .filter:hover {
    border-color: var(--color-navy);
    color: var(--color-navy);
  }
  .filter.is-active {
    background: var(--color-navy);
    border-color: var(--color-navy);
    color: #fff;
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .gitem {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    box-shadow: var(--shadow-sm);
    display: block;
    width: 100%;
  }
  .gitem.is-hidden {
    display: none;
  }
  .gitem img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease);
  }
  .gitem:hover img {
    transform: scale(1.08);
  }
  .gitem__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    padding: 1.3rem;
    text-align: left;
    background: linear-gradient(
      to top,
      rgba(8, 26, 50, 0.9) 0%,
      rgba(8, 26, 50, 0.3) 45%,
      rgba(8, 26, 50, 0) 75%
    );
    opacity: 0;
    transition: opacity 0.4s var(--ease);
  }
  .gitem:hover .gitem__overlay,
  .gitem:focus-visible .gitem__overlay {
    opacity: 1;
  }
  .gitem__cat {
    font-family: var(--font-heading);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.85);
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.25);
    padding: 0.25rem 0.7rem;
    border-radius: 999px;
    margin-bottom: 0.6rem;
  }
  .gitem__title {
    font-family: var(--font-heading);
    font-weight: 600;
    color: #fff;
    font-size: 1.05rem;
    transform: translateY(8px);
    transition: transform 0.4s var(--ease);
  }
  .gitem:hover .gitem__title {
    transform: none;
  }
  .gitem__zoom {
    position: absolute;
    top: 1.1rem;
    right: 1.1rem;
    width: 40px;
    height: 40px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: #fff;
    backdrop-filter: blur(4px);
  }

  .gallery__empty {
    text-align: center;
    color: var(--color-text-muted);
    padding: 2rem 0;
  }

  /* Modal */
  .modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: grid;
    place-items: center;
    padding: 1.5rem;
  }
  .modal[hidden] {
    display: none;
  }
  .modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(8, 26, 50, 0.85);
    backdrop-filter: blur(6px);
    animation: fade 0.3s var(--ease);
  }
  .modal__content {
    position: relative;
    z-index: 1;
    max-width: 1000px;
    width: 100%;
    animation: pop 0.35s var(--ease);
  }
  .modal__img {
    width: 100%;
    max-height: 78vh;
    object-fit: contain;
    border-radius: var(--radius);
    box-shadow: var(--shadow-lg);
  }
  .modal__close {
    position: absolute;
    top: -3.25rem;
    right: 0;
    width: 44px;
    height: 44px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: #fff;
    transition: background 0.2s;
  }
  .modal__close:hover {
    background: rgba(255, 255, 255, 0.25);
  }
  .modal__caption {
    margin-top: 1rem;
    text-align: center;
    color: #fff;
  }
  .modal__cat {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.65);
    margin-bottom: 0.25rem;
  }
  .modal__title {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 600;
  }
  @keyframes fade {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes pop {
    from { opacity: 0; transform: scale(0.96); }
    to { opacity: 1; transform: none; }
  }

  @media (max-width: 880px) {
    .gallery { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 540px) {
    .gallery { grid-template-columns: 1fr; }
    .modal__close { top: auto; bottom: -3.25rem; right: 50%; transform: translateX(50%); }
  }
</style>

<script>
  // Filtros
  const filterBtns = document.querySelectorAll<HTMLButtonElement>(".filter");
  const items = document.querySelectorAll<HTMLElement>(".gitem");
  const empty = document.getElementById("gallery-empty");

  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const key = btn.dataset.filter;
      filterBtns.forEach((b) => {
        b.classList.toggle("is-active", b === btn);
        b.setAttribute("aria-selected", String(b === btn));
      });
      let visible = 0;
      items.forEach((item) => {
        const show = key === "all" || item.dataset.category === key;
        item.classList.toggle("is-hidden", !show);
        if (show) visible++;
      });
      if (empty) empty.hidden = visible !== 0;
    });
  });

  // Modal
  const modal = document.getElementById("gallery-modal");
  const modalImg = document.getElementById("modal-img") as HTMLImageElement | null;
  const modalCat = document.getElementById("modal-cat");
  const modalTitle = document.getElementById("modal-title");
  let lastFocused: HTMLElement | null = null;

  const openModal = (item: HTMLElement) => {
    if (!modal || !modalImg) return;
    lastFocused = item;
    modalImg.src = item.dataset.full ?? "";
    modalImg.alt = item.dataset.title ?? "";
    if (modalCat) modalCat.textContent = item.dataset.label ?? "";
    if (modalTitle) modalTitle.textContent = item.dataset.title ?? "";
    modal.hidden = false;
    document.body.style.overflow = "hidden";
    modal.querySelector<HTMLButtonElement>(".modal__close")?.focus();
  };

  const closeModal = () => {
    if (!modal) return;
    modal.hidden = true;
    document.body.style.overflow = "";
    lastFocused?.focus();
  };

  items.forEach((item) => item.addEventListener("click", () => openModal(item)));
  modal
    ?.querySelectorAll("[data-modal-close]")
    .forEach((el) => el.addEventListener("click", closeModal));
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && modal && !modal.hidden) closeModal();
  });
</script>
