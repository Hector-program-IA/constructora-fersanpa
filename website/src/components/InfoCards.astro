---
import Icon from "./Icon.astro";

const cards = [
  {
    icon: "target",
    title: "Misión",
    text: "Nuestra misión es brindar soluciones constructivas de calidad, enfocadas en satisfacer las necesidades de nuestros clientes mediante procesos eficientes y profesionales.",
  },
  {
    icon: "vision",
    title: "Visión",
    text: "Nuestra visión es consolidarnos como una empresa referente en el sector de la construcción, destacando por la excelencia de nuestros proyectos y el compromiso con nuestros clientes.",
  },
  {
    icon: "gallery",
    title: "Galería",
    text: "Conoce algunos de los proyectos residenciales y comerciales desarrollados por nuestro equipo.",
    link: "#galeria",
  },
  {
    icon: "message",
    title: "Contacto",
    text: "Estamos listos para atender tus proyectos y resolver cualquier duda sobre nuestros servicios.",
    link: "#contacto",
  },
];
---

<section class="section" id="tarjetas">
  <div class="container">
    <div class="cards">
      {
        cards.map((c, i) => (
          <article
            class="card"
            data-reveal
            data-reveal-delay={String((i % 4) + 1)}
          >
            <span class="card__icon" aria-hidden="true">
              <Icon name={c.icon} size={26} />
            </span>
            <h3 class="card__title">{c.title}</h3>
            <p class="card__text">{c.text}</p>
            {c.link && (
              <a href={c.link} class="card__link">
                Ver más
                <Icon name="arrow" size={16} />
              </a>
            )}
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }
  .card {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2.25rem 1.75rem;
    box-shadow: var(--shadow-sm);
    transition: transform 0.4s var(--ease), box-shadow 0.4s var(--ease),
      border-color 0.4s var(--ease);
    display: flex;
    flex-direction: column;
  }
  .card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
    border-color: transparent;
  }
  .card__icon {
    display: inline-grid;
    place-items: center;
    width: 60px;
    height: 60px;
    border-radius: 16px;
    background: var(--color-accent);
    color: var(--color-navy);
    margin-bottom: 1.5rem;
    transition: background 0.4s var(--ease), color 0.4s var(--ease);
  }
  .card:hover .card__icon {
    background: var(--color-navy);
    color: #fff;
  }
  .card__title {
    font-size: 1.3rem;
    margin-bottom: 0.75rem;
  }
  .card__text {
    color: var(--color-text-muted);
    font-size: 0.96rem;
    flex: 1;
  }
  .card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1.25rem;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-navy);
  }
  .card__link svg {
    transition: transform 0.3s var(--ease);
  }
  .card__link:hover svg {
    transform: translateX(4px);
  }

  @media (max-width: 980px) {
    .cards { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 540px) {
    .cards { grid-template-columns: 1fr; }
  }
</style>
