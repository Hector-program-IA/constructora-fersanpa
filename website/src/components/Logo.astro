---
/**
 * Logo GB Constructora — monograma + wordmark.
 */
interface Props {
  variant?: "dark" | "light";
}
const { variant = "dark" } = Astro.props;
const textColor = variant === "light" ? "#ffffff" : "var(--color-navy)";
const subColor = variant === "light" ? "rgba(255,255,255,.7)" : "var(--color-steel)";
---

<a href="#inicio" class="logo" aria-label="GB Constructora — inicio">
  <span class="logo__mark" aria-hidden="true">
    <svg viewBox="0 0 48 48" width="44" height="44" fill="none">
      <rect x="1.5" y="1.5" width="45" height="45" rx="11" stroke="currentColor" stroke-width="1.6" opacity="0.35"/>
      <path d="M14 33V15h7.5c3.2 0 5.3 1.6 5.3 4.3 0 1.9-1 3.2-2.7 3.8 2 .5 3.2 2 3.2 4.1 0 3-2.3 4.8-5.8 4.8H14z" fill="currentColor"/>
      <path d="M30 33V15h6.5c4.6 0 7.5 3.6 7.5 9s-2.9 9-7.5 9H30z" fill="currentColor" opacity="0.55"/>
    </svg>
  </span>
  <span class="logo__text">
    <strong style={`color:${textColor}`}>GB</strong>
    <span style={`color:${subColor}`}>Constructora</span>
  </span>
</a>

<style define:vars={{ textColor, subColor }}>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
  }
  .logo__mark {
    color: var(--color-navy);
    display: inline-flex;
    transition: transform 0.3s var(--ease);
  }
  :global(.header--light) .logo__mark { color: #fff; }
  .logo:hover .logo__mark { transform: rotate(-4deg) scale(1.04); }
  .logo__text {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
    font-family: var(--font-heading);
  }
  .logo__text strong {
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: 0.04em;
  }
  .logo__text span {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
</style>
